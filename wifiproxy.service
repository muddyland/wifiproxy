[Unit]
Description=WiFi Bridge Web UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/wifiproxy
Environment="BIND_HOST=192.168.50.1"
Environment="PORT=80"
Environment="SECRET_KEY=CHANGE_ME_BEFORE_DEPLOY"
ExecStart=/opt/wifiproxy/venv/bin/python run.py
Restart=on-failure
RestartSec=5

# Harden the service process
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
